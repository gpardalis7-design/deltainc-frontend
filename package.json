{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-site-artifacts.mjs && vite build && node scripts/generate-social-pages.mjs && node scripts/verify-social-previews.mjs",
    "dev": "vite",
    "generate:site-artifacts": "node scripts/generate-site-artifacts.mjs",
    "verify:social": "node scripts/verify-social-previews.mjs",
    "verify:deploy": "node scripts/post-deploy-verify.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:clean": "tsc --noEmit --noUnusedLocals --noUnusedParameters"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/manrope": "5.2.8",
    "clsx": "2.1.1",
    "dompurify": "3.4.10",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "react-helmet-async": "^3.0.0",
    "react-router": "7.17.0",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@rollup/wasm-node": "^4.60.2",
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "4.7.0",
    "lightningcss-darwin-arm64": "1.30.1",
    "node-html-parser": "^8.0.2",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.3",
    "vite": "6.3.5"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
